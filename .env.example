# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/maverick_cert_hub?schema=public"

# Application
APP_URL="http://localhost:3000"
NODE_ENV="development"

# Security — generate with: openssl rand -hex 32
ENCRYPTION_KEY="your-32-byte-hex-encryption-key-here"
TOKEN_SECRET="your-token-signing-secret-here"

# Mock services
MOCK_EMAIL_ENABLED="true"

# Microsoft Entra ID (future)
MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""
MICROSOFT_TENANT_ID=""

# Microsoft Graph (future)
GRAPH_MAILBOX_ADDRESS=""

# Azure Key Vault (future)
AZURE_KEY_VAULT_URL=""

# Azure OpenAI (GenAI features)
AZURE_OPENAI_ENDPOINT=""
AZURE_OPENAI_API_KEY=""
AZURE_OPENAI_DEPLOYMENT="gpt-4o"
AZURE_OPENAI_API_VERSION="2024-08-01-preview"

# AWS Cognito (Authentication)
COGNITO_USER_POOL_ID=""
COGNITO_CLIENT_ID=""
COGNITO_REGION="ap-southeast-2"

# AWS Bedrock (GenAI features)
AWS_BEDROCK_ACCESS_KEY=""
AWS_BEDROCK_SECRET_KEY=""
AWS_BEDROCK_REGION="ap-southeast-2"
AWS_BEDROCK_MODEL="amazon.nova-pro-v1:0"
